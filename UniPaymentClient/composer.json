{
  "name": "unipayment/client",
  "description": "UniPayment Client",
  "version": "1.0.0",
  "keywords": [
    "php",
    "sdk",
    "api"
  ],
  "homepage": "https://unipayment.io",
  "license": "proprietary",
  "authors": [
    {
      "name": "UniPayment",
      "homepage": "https://unipayment.io"
    }
  ],
  "require": {
    "php": "^7.3 || ^8.0",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "guzzlehttp/guzzle": "^6.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.1"
  },
  "autoload": {
    "psr-4": {
      "UniPayment\\Client\\": "lib/"
